{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:assure:schema:scanner-policy:v1",
  "title": "Assure repository scanner policy v1",
  "description": "The raise-only repository policy read from exactly .assure/scanner-policy.json.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "document_includes",
    "protected_inventory",
    "finding_dispositions"
  ],
  "properties": {
    "schema": {
      "const": "assure/scanner-policy/v1"
    },
    "document_includes": {
      "type": "array",
      "maxItems": 100000,
      "description": "Exact repository paths only. Sort by path UTF-8 bytes, then kind.",
      "x-assure-order": [
        "path",
        "kind"
      ],
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/DocumentInclude"
      }
    },
    "protected_inventory": {
      "type": "array",
      "maxItems": 100000,
      "description": "Exact document paths only. Sort by RepoPath UTF-8 bytes.",
      "x-assure-order": [
        "RepoPath"
      ],
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/RepoPath"
      }
    },
    "finding_dispositions": {
      "type": "array",
      "maxItems": 3,
      "description": "Raise-only overrides. Sort by finding_kind UTF-8 bytes.",
      "x-assure-order": [
        "finding_kind"
      ],
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/FindingDisposition"
      }
    }
  },
  "$defs": {
    "RepoPath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096,
      "pattern": "^(?!/)(?![\\s\\S]*//)(?![\\s\\S]*(?:^|/)(?:\\.{1,2})(?:/|$))(?![\\s\\S]*[\\\\\\u0000])[^/]+(?:/[^/]+)*$",
      "description": "Strict UTF-8 repository-relative path using slash separators; byte limits and UTF-8 validity are additionally enforced before JSON decoding."
    },
    "DocumentInclude": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path",
        "kind"
      ],
      "properties": {
        "path": {
          "$ref": "#/$defs/RepoPath"
        },
        "kind": {
          "enum": [
            "document",
            "tree"
          ]
        }
      }
    },
    "FindingKind": {
      "enum": [
        "explicit-target-missing",
        "explicit-target-type-mismatch",
        "invalid-reference"
      ]
    },
    "FindingDisposition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finding_kind",
        "disposition"
      ],
      "properties": {
        "finding_kind": {
          "$ref": "#/$defs/FindingKind"
        },
        "disposition": {
          "enum": [
            "warn",
            "fail"
          ]
        }
      }
    }
  }
}
