{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:amiss:schema:scanner-release-manifest",
  "title": "Amiss scanner release manifest",
  "description": "The rolling reviewed release manifest. The typed parser additionally recomputes dependency_lock_digest, requires artifacts to be sorted and unique by platform, requires runtime_files to be sorted and unique by path, and binds the single executable row's path and digest to tree_path and binary_sha256.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "engine_version",
    "build_source",
    "dependency_lock",
    "dependency_lock_digest",
    "artifacts"
  ],
  "properties": {
    "schema": {
      "const": "amiss/scanner-release-manifest"
    },
    "engine_version": {
      "type": "string",
      "minLength": 5,
      "maxLength": 64,
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:-[a-z0-9.-]+)?$"
    },
    "build_source": {
      "$ref": "#/$defs/BuildSource"
    },
    "dependency_lock": {
      "$ref": "#/$defs/DependencyLockInput"
    },
    "dependency_lock_digest": {
      "$ref": "#/$defs/Digest"
    },
    "artifacts": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "description": "Sorted and unique by platform UTF-8 bytes.",
      "x-amiss-order": ["platform"],
      "items": {
        "$ref": "#/$defs/ReleaseArtifact"
      }
    }
  },
  "$defs": {
    "Digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    },
    "ArtifactId": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^[a-z0-9][a-z0-9._/-]*$"
    },
    "RepoPath": {
      "type": "string",
      "minLength": 1,
      "maxLength": 4096,
      "pattern": "^(?!/)(?![\\s\\S]*//)(?![\\s\\S]*(?:^|/)(?:\\.{1,2})(?:/|$))(?![\\s\\S]*[\\\\\\u0000])[^/]+(?:/[^/]+)*$"
    },
    "RepositoryIdentity": {
      "type": "object",
      "description": "An opaque caller-canonical host, slash-joined owner segments, and repository name.",
      "additionalProperties": false,
      "required": ["host", "owner", "name"],
      "properties": {
        "host": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255,
          "pattern": "^[^/]+$"
        },
        "owner": {
          "type": "string",
          "minLength": 1,
          "maxLength": 255,
          "pattern": "^[a-z0-9](?:[a-z0-9._-]{0,98}[a-z0-9])?(?:/[a-z0-9](?:[a-z0-9._-]{0,98}[a-z0-9])?)*$"
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "pattern": "^(?!\\.{1,2}$)[a-z0-9._-]{1,100}$"
        }
      }
    },
    "Sha1Oid": {
      "type": "string",
      "pattern": "^[0-9a-f]{40}$"
    },
    "Sha256Oid": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "BuildSource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repository", "object_format", "commit_oid"],
      "properties": {
        "repository": {
          "$ref": "#/$defs/RepositoryIdentity"
        },
        "object_format": {
          "enum": ["sha1", "sha256"]
        },
        "commit_oid": {
          "oneOf": [
            {"$ref": "#/$defs/Sha1Oid"},
            {"$ref": "#/$defs/Sha256Oid"}
          ]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {"object_format": {"const": "sha1"}},
            "required": ["object_format"]
          },
          "then": {
            "properties": {"commit_oid": {"$ref": "#/$defs/Sha1Oid"}}
          },
          "else": {
            "properties": {"commit_oid": {"$ref": "#/$defs/Sha256Oid"}}
          }
        }
      ]
    },
    "DependencyLockInput": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema", "files"],
      "properties": {
        "schema": {
          "const": "amiss/scanner-dependency-lock-input"
        },
        "files": {
          "type": "array",
          "minItems": 1,
          "maxItems": 32,
          "description": "Sorted and unique by path UTF-8 bytes.",
          "x-amiss-order": ["path"],
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["path", "raw_digest"],
            "properties": {
              "path": {"$ref": "#/$defs/RepoPath"},
              "raw_digest": {"$ref": "#/$defs/Digest"}
            }
          }
        }
      }
    },
    "Platform": {
      "enum": [
        "linux-aarch64",
        "linux-x86_64",
        "macos-aarch64",
        "macos-x86_64",
        "windows-aarch64",
        "windows-x86_64"
      ]
    },
    "RuntimeFile": {
      "oneOf": [
        {
          "allOf": [
            {"$ref": "#/$defs/RuntimeFileBase"},
            {
              "properties": {
                "role": {"const": "executable"},
                "git_mode": {"const": "100755"}
              }
            }
          ]
        },
        {
          "allOf": [
            {"$ref": "#/$defs/RuntimeFileBase"},
            {
              "properties": {
                "role": {"const": "launcher"},
                "git_mode": {"const": "100644"}
              }
            }
          ]
        },
        {
          "allOf": [
            {"$ref": "#/$defs/RuntimeFileBase"},
            {
              "properties": {
                "role": {"enum": ["dynamic-library", "runtime-data"]},
                "git_mode": {"enum": ["100644", "100755"]}
              }
            }
          ]
        }
      ]
    },
    "RuntimeFileBase": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "role", "git_mode", "file_sha256"],
      "properties": {
        "path": {"$ref": "#/$defs/RepoPath"},
        "role": {
          "enum": ["executable", "launcher", "dynamic-library", "runtime-data"]
        },
        "git_mode": {
          "enum": ["100644", "100755"]
        },
        "file_sha256": {"$ref": "#/$defs/Digest"}
      }
    },
    "ReleaseArtifact": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "platform",
        "artifact_name",
        "tree_path",
        "binary_sha256",
        "engine_digest",
        "runtime_contract",
        "environment_contract",
        "runtime_files"
      ],
      "properties": {
        "platform": {"$ref": "#/$defs/Platform"},
        "artifact_name": {"$ref": "#/$defs/ArtifactId"},
        "tree_path": {"$ref": "#/$defs/RepoPath"},
        "binary_sha256": {"$ref": "#/$defs/Digest"},
        "engine_digest": {"$ref": "#/$defs/Digest"},
        "runtime_contract": {"const": "manifest-closed"},
        "environment_contract": {"const": "scanner-process-env"},
        "runtime_files": {
          "type": "array",
          "minItems": 1,
          "maxItems": 256,
          "description": "Sorted and unique by path UTF-8 bytes, with exactly one executable and one launcher.",
          "x-amiss-order": ["path"],
          "items": {"$ref": "#/$defs/RuntimeFile"},
          "allOf": [
            {
              "contains": {
                "type": "object",
                "required": ["role"],
                "properties": {"role": {"const": "executable"}}
              },
              "minContains": 1,
              "maxContains": 1
            },
            {
              "contains": {
                "type": "object",
                "required": ["role"],
                "properties": {"role": {"const": "launcher"}}
              },
              "minContains": 1,
              "maxContains": 1
            }
          ]
        }
      }
    }
  }
}
