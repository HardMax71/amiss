{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:assure:schema:scanner-controls-request:v1",
  "title": "Assure scanner controls request v1",
  "description": "The external-control request of the wrapper-to-engine wire. Each supplied control embeds its exact JSON value beside the independently acquired expected semantic digest and the external trust source that authorized it; the engine recomputes every digest and rejects any mismatch. Absent members are null. Its diagnostic digest domain is assure/scanner-controls-request/v1 over the exact bytes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "organization_floor",
    "debt_snapshot",
    "waiver_bundle",
    "trusted_time",
    "execution_constraint"
  ],
  "properties": {
    "schema": {
      "const": "assure/scanner-controls-request/v1"
    },
    "organization_floor": {
      "oneOf": [{ "$ref": "#/$defs/SuppliedControl" }, { "type": "null" }]
    },
    "debt_snapshot": {
      "oneOf": [{ "$ref": "#/$defs/SuppliedControl" }, { "type": "null" }]
    },
    "waiver_bundle": {
      "oneOf": [{ "$ref": "#/$defs/SuppliedControl" }, { "type": "null" }]
    },
    "trusted_time": {
      "oneOf": [{ "$ref": "#/$defs/SuppliedTime" }, { "type": "null" }]
    },
    "execution_constraint": {
      "oneOf": [{ "$ref": "#/$defs/SuppliedControl" }, { "type": "null" }]
    }
  },
  "$defs": {
    "SuppliedControl": {
      "type": "object",
      "additionalProperties": false,
      "required": ["value", "expected_digest", "trust_source"],
      "properties": {
        "value": {
          "description": "The exact control JSON value under its own schema. The per-control raw ceiling (control-input-bytes) applies to its canonical bytes before typed parsing.",
          "type": "object"
        },
        "expected_digest": {
          "$ref": "#/$defs/Digest"
        },
        "trust_source": {
          "enum": ["external-required-workflow", "organization-ruleset"]
        }
      }
    },
    "SuppliedTime": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "value",
        "expected_digest",
        "provider_run_id",
        "provider_run_attempt"
      ],
      "properties": {
        "value": {
          "description": "The exact trusted-time statement value. Its trust source is fixed: external-required-workflow.",
          "type": "object"
        },
        "expected_digest": {
          "$ref": "#/$defs/Digest"
        },
        "provider_run_id": {
          "type": "string",
          "minLength": 1,
          "maxLength": 32,
          "pattern": "^[1-9][0-9]*$"
        },
        "provider_run_attempt": {
          "type": "integer",
          "minimum": 1,
          "maximum": 9007199254740991
        }
      }
    },
    "Digest": {
      "type": "string",
      "pattern": "^sha256:[0-9a-f]{64}$"
    }
  }
}
