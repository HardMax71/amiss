          "digest": "sha256:1290e8ba186bf8034b1640164f96cd0c61d7b5b220f2f8e35606eadf8d328288",
          "multiplicity": 1
        },
        {
          "digest": "sha256:dcd47032a2e45b4ca52c664a5b164cd12ff96d44cf0d8b73058f8f0068cd0227",
          "multiplicity": 1
        }
      ]
    }
  ]
}
