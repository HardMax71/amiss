{
  "schema": "amiss/gitignore-vectors",
  "contract": "gitignore",
  "reference": {
    "git_version": "2.42.0",
    "modes": [
      {
        "entry_state": "untracked",
        "setup": null,
        "command": "git check-ignore --no-index -q -- <path>"
      },
      {
        "entry_state": "tracked",
        "setup": "git add -f -- <path>",
        "command": "git check-ignore -q -- <path>"
      }
    ],
    "locale": "C"
  },
  "cases": [
    {
      "id": "GI-001",
      "description": "Blank and comment lines match nothing.",
      "files": [
        { "path": ".gitignore", "tracked": true, "kind": "regular", "content_utf8": "\n# comment\n" }
      ],
      "consulted": [".gitignore"],
      "entries": [
        { "path": "comment", "tracked": false, "kind": "regular", "ignored": false }
      ]
    },
    {
      "id": "GI-002",
      "description": "Escaped leading hash and bang are literals.",
      "files": [
        { "path": ".gitignore", "tracked": true, "kind": "regular", "content_utf8": "\\#literal\n\\!literal\n" }
      ],
      "consulted": [".gitignore"],
      "entries": [
        { "path": "#literal", "tracked": false, "kind": "regular", "ignored": true },
        { "path": "!literal", "tracked": false, "kind": "regular", "ignored": true }
      ]
    },
    {
      "id": "GI-003",
      "description": "Unescaped trailing spaces are trimmed and escaped trailing space is literal.",
      "files": [
        { "path": ".gitignore", "tracked": true, "kind": "regular", "content_utf8": "foo   \nbar\\ \n" }
      ],
      "consulted": [".gitignore"],
      "entries": [
        { "path": "foo", "tracked": false, "kind": "regular", "ignored": true },
        { "path": "foo   ", "tracked": false, "kind": "regular", "ignored": false },
        { "path": "bar ", "tracked": false, "kind": "regular", "ignored": true }
      ]
    },
    {
      "id": "GI-004",
      "description": "A slashless basename pattern matches at every level.",
      "files": [
        { "path": ".gitignore", "tracked": true, "kind": "regular", "content_utf8": "build\n" }
      ],
      "consulted": [".gitignore"],
      "entries": [
        { "path": "build", "tracked": false, "kind": "regular", "ignored": true },
        { "path": "a/build", "tracked": false, "kind": "directory", "ignored": true }
      ]
    },
    {
      "id": "GI-005",
      "description": "A leading slash anchors at the containing directory.",
      "files": [
        { "path": ".gitignore", "tracked": true, "kind": "regular", "content_utf8": "/root.txt\n" }
      ],
      "consulted": [".gitignore"],
      "entries": [
        { "path": "root.txt", "tracked": false, "kind": "regular", "ignored": true },
        { "path": "a/root.txt", "tracked": false, "kind": "regular", "ignored": false }
      ]
    },
    {
      "id": "GI-006",
      "description": "A middle slash makes the pattern relative to its containing directory.",
      "files": [
        { "path": ".gitignore", "tracked": true, "kind": "regular", "content_utf8": "doc/frotz\n" }
      ],
      "consulted": [".gitignore"],
      "entries": [
        { "path": "doc/frotz", "tracked": false, "kind": "directory", "ignored": true },
        { "path": "a/doc/frotz", "tracked": false, "kind": "directory", "ignored": false }
      ]
    },
    {
      "id": "GI-007",
      "description": "A trailing slash matches directories, not regular files or symlinks.",
      "files": [
        { "path": ".gitignore", "tracked": true, "kind": "regular", "content_utf8": "cache/\n" }
      ],
      "consulted": [".gitignore"],
      "entries": [
        { "path": "cache", "tracked": false, "kind": "directory", "ignored": true },
        { "path": "cache", "tracked": false, "kind": "regular", "ignored": false },
        { "path": "cache", "tracked": false, "kind": "symlink", "ignored": false }
      ]
    },
    {
      "id": "GI-008",
      "description": "Star, question mark, and byte-range tokens do not cross slash.",
      "files": [
        { "path": ".gitignore", "tracked": true, "kind": "regular", "content_utf8": "*.o\nfile?.txt\nasset[0-2].png\n" }
      ],
      "consulted": [".gitignore"],
      "entries": [
        { "path": "src/a.o", "tracked": false, "kind": "regular", "ignored": true },
        { "path": "file1.txt", "tracked": false, "kind": "regular", "ignored": true },
        { "path": "file12.txt", "tracked": false, "kind": "regular", "ignored": false },
        { "path": "asset2.png", "tracked": false, "kind": "regular", "ignored": true },
        { "path": "asset3.png", "tracked": false, "kind": "regular", "ignored": false }
      ]
    },
    {
      "id": "GI-009",
      "description": "Backslash escapes a wildcard byte.",
      "files": [
        { "path": ".gitignore", "tracked": true, "kind": "regular", "content_utf8": "literal\\*.txt\n" }
      ],
      "consulted": [".gitignore"],
      "entries": [
        { "path": "literal*.txt", "tracked": false, "kind": "regular", "ignored": true },
        { "path": "literalX.txt", "tracked": false, "kind": "regular", "ignored": false }
      ]
    },
    {
      "id": "GI-010",
      "description": "A trailing escape is an invalid pattern that never matches.",
      "files": [
        { "path": ".gitignore", "tracked": true, "kind": "regular", "content_utf8": "never\\" }
      ],
      "consulted": [".gitignore"],
      "entries": [
        { "path": "never", "tracked": false, "kind": "regular", "ignored": false }
      ]
    },
    {
      "id": "GI-011",
      "description": "The last matching negation re-includes a path.",
      "files": [
        { "path": ".gitignore", "tracked": true, "kind": "regular", "content_utf8": "*.log\n!important.log\n" }
      ],
      "consulted": [".gitignore"],
      "entries": [
        { "path": "other.log", "tracked": false, "kind": "regular", "ignored": true },
        { "path": "important.log", "tracked": false, "kind": "regular", "ignored": false }
      ]
    },
    {
      "id": "GI-012",
      "description": "An excluded parent prevents traversal and nested re-inclusion.",
      "files": [
        { "path": ".gitignore", "tracked": true, "kind": "regular", "content_utf8": "dir/\n" },
        { "path": "dir/.gitignore", "tracked": false, "kind": "regular", "content_utf8": "!file.md\n" }
      ],
      "consulted": [".gitignore"],
      "entries": [
        { "path": "dir", "tracked": false, "kind": "directory", "ignored": true },
        { "path": "dir/file.md", "tracked": false, "kind": "regular", "ignored": true }
      ]
    },
    {
      "id": "GI-013",
      "description": "Re-including each parent permits a selected descendant subtree.",
      "files": [
        { "path": ".gitignore", "tracked": true, "kind": "regular", "content_utf8": "/*\n!/foo\n/foo/*\n!/foo/bar\n" }
      ],
      "consulted": [".gitignore"],
      "entries": [
        { "path": "other", "tracked": false, "kind": "directory", "ignored": true },
        { "path": "foo", "tracked": false, "kind": "directory", "ignored": false },
        { "path": "foo/bar", "tracked": false, "kind": "directory", "ignored": false },
        { "path": "foo/bar/file.md", "tracked": false, "kind": "regular", "ignored": false }
      ]
    },
    {
      "id": "GI-014",
      "description": "A deeper gitignore overrides an ancestor rule.",
      "files": [
        { "path": ".gitignore", "tracked": true, "kind": "regular", "content_utf8": "*.tmp\n" },
        { "path": "sub/.gitignore", "tracked": false, "kind": "regular", "content_utf8": "!keep.tmp\n" }
      ],
      "consulted": [".gitignore", "sub/.gitignore"],
      "entries": [
        { "path": "sub/drop.tmp", "tracked": false, "kind": "regular", "ignored": true },
        { "path": "sub/keep.tmp", "tracked": false, "kind": "regular", "ignored": false }
      ]
    },
    {
      "id": "GI-015",
      "description": "Leading double-star plus slash matches at every depth.",
      "files": [
        { "path": ".gitignore", "tracked": true, "kind": "regular", "content_utf8": "**/foo\n" }
      ],
      "consulted": [".gitignore"],
      "entries": [
        { "path": "foo", "tracked": false, "kind": "regular", "ignored": true },
        { "path": "a/b/foo", "tracked": false, "kind": "regular", "ignored": true }
      ]
    },
    {
      "id": "GI-016",
      "description": "Trailing slash-double-star matches everything inside, not the directory itself.",
      "files": [
        { "path": ".gitignore", "tracked": true, "kind": "regular", "content_utf8": "abc/**\n" }
      ],
      "consulted": [".gitignore"],
      "entries": [
        { "path": "abc", "tracked": false, "kind": "directory", "ignored": false },
        { "path": "abc/x", "tracked": false, "kind": "regular", "ignored": true },
        { "path": "abc/x/y", "tracked": false, "kind": "regular", "ignored": true }
      ]
    },
    {
      "id": "GI-017",
      "description": "Slash-double-star-slash matches zero or more directories.",
      "files": [
        { "path": ".gitignore", "tracked": true, "kind": "regular", "content_utf8": "a/**/b\n" }
      ],
      "consulted": [".gitignore"],
      "entries": [
        { "path": "a/b", "tracked": false, "kind": "regular", "ignored": true },
        { "path": "a/x/b", "tracked": false, "kind": "regular", "ignored": true },
        { "path": "a/x/y/b", "tracked": false, "kind": "regular", "ignored": true }
      ]
    },
    {
      "id": "GI-018",
      "description": "Other consecutive stars have ordinary star behavior.",
      "files": [
        { "path": ".gitignore", "tracked": true, "kind": "regular", "content_utf8": "a/***b\n" }
      ],
      "consulted": [".gitignore"],
      "entries": [
        { "path": "a/xxb", "tracked": false, "kind": "regular", "ignored": true },
        { "path": "a/x/xb", "tracked": false, "kind": "regular", "ignored": false }
      ]
    },
    {
      "id": "GI-019",
      "description": "Matching is case-sensitive and performs no Unicode normalization.",
      "files": [
        { "path": ".gitignore", "tracked": true, "kind": "regular", "content_utf8": "Readme.md\ncafé\n" }
      ],
      "consulted": [".gitignore"],
      "entries": [
        { "path": "Readme.md", "tracked": false, "kind": "regular", "ignored": true },
        { "path": "readme.md", "tracked": false, "kind": "regular", "ignored": false },
        { "path": "café", "tracked": false, "kind": "regular", "ignored": true },
        { "path": "café", "tracked": false, "kind": "regular", "ignored": false }
      ]
    },
    {
      "id": "GI-020",
      "description": "CRLF input and a final line without terminator follow the pinned oracle.",
      "files": [
        { "path": ".gitignore", "tracked": false, "kind": "regular", "content_utf8": "*.tmp\r\n!keep.tmp\r\nlast" }
      ],
      "consulted": [".gitignore"],
      "entries": [
        { "path": "drop.tmp", "tracked": false, "kind": "regular", "ignored": true },
        { "path": "keep.tmp", "tracked": false, "kind": "regular", "ignored": false },
        { "path": "last", "tracked": false, "kind": "regular", "ignored": true }
      ]
    },
    {
      "id": "GI-021",
      "description": "Ignore rules never remove tracked paths.",
      "files": [
        { "path": ".gitignore", "tracked": true, "kind": "regular", "content_utf8": "*.md\n" }
      ],
      "consulted": [".gitignore"],
      "entries": [
        { "path": "tracked.md", "tracked": true, "kind": "regular", "ignored": false },
        { "path": "untracked.md", "tracked": false, "kind": "regular", "ignored": true }
      ]
    },
    {
      "id": "GI-022",
      "description": "An untracked gitignore in a traversed directory participates.",
      "files": [
        { "path": "sub/.gitignore", "tracked": false, "kind": "regular", "content_utf8": "generated.md\n" }
      ],
      "consulted": ["sub/.gitignore"],
      "entries": [
        { "path": "sub/generated.md", "tracked": false, "kind": "regular", "ignored": true }
      ]
    },
    {
      "id": "GI-023",
      "description": "A gitignore symlink is not consulted or followed.",
      "files": [
        { "path": ".gitignore", "tracked": false, "kind": "symlink", "content_utf8": "ignored\n" }
      ],
      "consulted": [],
      "entries": [
        { "path": "ignored", "tracked": false, "kind": "regular", "ignored": false }
      ]
    },
    {
      "id": "GI-024",
      "description": "A leading space prevents comment interpretation.",
      "files": [
        { "path": ".gitignore", "tracked": true, "kind": "regular", "content_utf8": " #literal\n" }
      ],
      "consulted": [".gitignore"],
      "entries": [
        { "path": " #literal", "tracked": false, "kind": "regular", "ignored": true },
        { "path": "#literal", "tracked": false, "kind": "regular", "ignored": false }
      ]
    },
    {
      "id": "GI-025",
      "description": "POSIX named character classes use the pinned C-locale wildmatch behavior.",
      "files": [
        { "path": ".gitignore", "tracked": true, "kind": "regular", "content_utf8": "file[[:digit:]].txt\n" }
      ],
      "consulted": [".gitignore"],
      "entries": [
        { "path": "file7.txt", "tracked": false, "kind": "regular", "ignored": true },
        { "path": "filex.txt", "tracked": false, "kind": "regular", "ignored": false }
      ]
    },
    {
      "id": "GI-026",
      "description": "A traversed untracked gitignore is consulted even when its own rule ignores it.",
      "files": [
        { "path": ".gitignore", "tracked": false, "kind": "regular", "content_utf8": ".gitignore\n*.tmp\n" }
      ],
      "consulted": [".gitignore"],
      "entries": [
        { "path": ".gitignore", "tracked": false, "kind": "regular", "ignored": true },
        { "path": "drop.tmp", "tracked": false, "kind": "regular", "ignored": true }
      ]
    }
  ]
}
