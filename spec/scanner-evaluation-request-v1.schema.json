{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "urn:assure:schema:scanner-evaluation-request:v1",
  "title": "Assure scanner evaluation request v1",
  "description": "The run-identity request of the wrapper-to-engine wire: profile, mode, and the exact snapshot identities to evaluate. One complete bounded byte stream; its diagnostic digest domain is assure/scanner-evaluation-request/v1 over the exact bytes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema",
    "profile",
    "mode",
    "object_format",
    "repository",
    "ref",
    "default_branch_ref",
    "base_commit_oid",
    "candidate_commit_oid"
  ],
  "properties": {
    "schema": {
      "const": "assure/scanner-evaluation-request/v1"
    },
    "profile": {
      "enum": ["observe", "enforce"]
    },
    "mode": {
      "description": "commit-pair evaluates two explicit commits; index evaluates the base commit against the complete logical staged index. candidate_commit_oid is null exactly when mode is index.",
      "enum": ["commit-pair", "index"]
    },
    "object_format": {
      "enum": ["sha1", "sha256"]
    },
    "repository": {
      "oneOf": [{ "$ref": "#/$defs/RepositoryIdentity" }, { "type": "null" }]
    },
    "ref": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 12,
          "maxLength": 266,
          "pattern": "^refs/heads/[^\\\\\\u0000-\\u001f\\u007f ]+$"
        },
        { "type": "null" }
      ]
    },
    "default_branch_ref": {
      "oneOf": [
        {
          "type": "string",
          "minLength": 12,
          "maxLength": 266,
          "pattern": "^refs/heads/[^\\\\\\u0000-\\u001f\\u007f ]+$"
        },
        { "type": "null" }
      ]
    },
    "base_commit_oid": {
      "$ref": "#/$defs/GitOid"
    },
    "candidate_commit_oid": {
      "oneOf": [{ "$ref": "#/$defs/GitOid" }, { "type": "null" }]
    }
  },
  "$defs": {
    "RepositoryIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["host", "owner", "name"],
      "properties": {
        "host": {
          "const": "github.com"
        },
        "owner": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-z0-9](?:[a-z0-9._-]{0,98}[a-z0-9])?$",
          "maxLength": 100
        },
        "name": {
          "type": "string",
          "minLength": 1,
          "pattern": "^(?!\\.{1,2}$)[a-z0-9._-]{1,100}$",
          "maxLength": 100
        }
      }
    },
    "GitOid": {
      "oneOf": [
        { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      ]
    }
  }
}
